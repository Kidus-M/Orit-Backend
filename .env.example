# Neon pooled connection string used by Next.js route handlers.
DATABASE_URL=

# Neon direct/unpooled connection string used by Drizzle migrations.
DATABASE_URL_UNPOOLED=

# Long random values for hashing device sessions and protecting internal routes.
PASSWORD_PEPPER=replace-with-at-least-32-random-characters
SESSION_TOKEN_PEPPER=
ADMIN_API_KEY=
CRON_SECRET=

PICKUP_SECURITY_PEPPER=replace-with-at-least-32-random-characters
PUBLIC_APP_URL=https://orit-backend.vercel.app
PICKUP_QR_TTL_DAYS=30
LEYOU_SERVICE_CODE=1100
DEMO_PICKUP_TOKEN=demo-pickup-token-change-me
# Only enable this for demos/development.
SEED_IF_EMPTY=true
DEMO_MEMBER_TOKEN=demo-member-token-change-me
DEMO_STORE_OWNER_TOKEN=demo-store-token-change-me
DEMO_ADMIN_TOKEN=demo-admin-token-change-me

# Stripe test keys. Never send/store raw card numbers or CVV.
PAYMENT_MODE=mock
STRIPE_PUBLISHABLE_KEY=
STRIPE_CURRENCY=usd
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vendor case-order notifications through Resend.
# Verify orittej.com in Resend before using an @orittej.com sender.
RESEND_API_KEY=
VENDOR_ORDER_FROM_EMAIL=Orit Tej <orders@orittej.com>
